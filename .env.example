# Copy this to .env and fill in your keys

# ── LLM Provider (lm_studio | openai) ─────────────────────────────────────────
DEFAULT_PROVIDER=lm_studio

# ── LM Studio (local) ─────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b
LM_STUDIO_VISION_MODEL=qwen/qwen3.5-9b

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Uses the Responses API (client.responses.create) — the primary API for gpt-5+ models.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ── Tavily (web search) ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Whisper transcription ──────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large (larger = more accurate)
WHISPER_MODEL=base

# ── Pipeline ───────────────────────────────────────────────────────────────────
MAX_ALIGNMENT_ITERATIONS=3
# Max web-search rounds before the researcher is forced to synthesise (prevents loops)
MAX_RESEARCH_TOOL_ROUNDS=6
# Max Tavily searches the alignment agent runs to fact-check gaps (0 = disabled)
MAX_ALIGNMENT_SEARCH_ROUNDS=3
# Enable post-research evidence enrichment in the synthesis agent (default off)
SYNTHESIS_SEARCH_ENABLED=false
# Max Tavily searches the synthesis agent runs for evidence (only when SYNTHESIS_SEARCH_ENABLED=true)
MAX_SYNTHESIS_SEARCH_ROUNDS=3

# ── Frame extraction ───────────────────────────────────────────────────────────
# Pixel diff threshold (0-255, lower = more sensitive)
FRAME_DIFF_THRESHOLD=30
# Mouse movement bounding box (changes smaller than this are ignored)
MOUSE_REGION_SIZE=50
# Max number of keyframes sent to the vision LLM for description
MAX_FRAMES_DESCRIBED=100
# Hard cap on total keyframes extracted (prevents runaway on long videos)
MAX_KEYFRAMES=60
# Process every Nth video frame during extraction (2 = half FPS, 3 = one-third FPS)
FRAME_SAMPLE_RATE=2
# Parallel workers for vision description (1=sequential with full chain context)
# Use >1 only with OpenAI — LM Studio queues on a single GPU so parallelism has no effect
FRAME_DESCRIPTION_WORKERS=1

# ── Video downscale ────────────────────────────────────────────────────────────
# Max width in pixels before processing (0 = no downscale)
VIDEO_MAX_WIDTH=480
